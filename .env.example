# Admin — connexion par email / mot de passe (voir pages/admin/login)
NUXT_ADMIN_EMAIL=
NUXT_ADMIN_PASSWORD=
# Secret pour signer les JWT (min. 32 caractères), ex. openssl rand -hex 32
NUXT_ADMIN_SESSION_SECRET=

# Optionnel : jeton Bearer fixe (legacy), ou repli si NUXT_ADMIN_SESSION_SECRET est vide
NUXT_ADMIN_TOKEN=

# PayTech : même couple que sur le tableau marchand (requête request-payment).
# NUXT_PAYTECH_API_KEY → header HTTP « API_KEY » (identifiant / clé côté doc souvent appelée « publique »).
# NUXT_PAYTECH_API_SECRET → header « API_SECRET » (clé secrète — uniquement serveur, jamais dans le navigateur).
NUXT_PAYTECH_API_KEY=
NUXT_PAYTECH_API_SECRET=
# URL publique du site (succès / annulation PayTech ; idéalement https en prod).
NUXT_PUBLIC_SITE_URL=http://localhost:3000
# Optionnel : HTTPS public utilisé uniquement pour l’IPN PayTech (même chemin /api/paytech/ipn).
# En local avec http://localhost : tunnel ngrok/cloudflared vers ce serveur, ex. https://abc.ngrok-free.app
# NUXT_PAYTECH_IPN_PUBLIC_URL=https://abc.ngrok-free.app

# Dev uniquement : ne pas vérifier HMAC / SHA256 sur l’IPN PayTech (jamais en prod)
# NUXT_PAYTECH_IPN_SKIP_VERIFY=true

# Espace client (cookie httpOnly) — obligatoire pour /compte, login, favoris.
# Même idée que NUXT_ADMIN_SESSION_SECRET : min. 32 octets aléatoires, ex. openssl rand -hex 32
NUXT_CUSTOMER_SESSION_SECRET=

# Emails via Resend (https://resend.com) : commande payée + demandes formulaire Contact → NUXT_MAIL_TO_SHOP
# NUXT_RESEND_API_KEY=
# NUXT_MAIL_FROM=WAXTU <onboarding@resend.dev>
# Destinataire interne (boutique) — variable Nuxt : mailToShop
# Avec NUXT_MAIL_FROM=…@resend.dev (test) : Resend n’accepte souvent que l’email du compte Resend.
# Pour notifier une autre adresse : vérifie un domaine sur resend.com/domains puis FROM du type commandes@votredomaine.com
# NUXT_MAIL_TO_SHOP=votre@email.com
